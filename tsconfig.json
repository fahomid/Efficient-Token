{
  "compilerOptions": {
    /* Language / module — ESM on NodeNext (local imports MUST carry .js). */
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    /* Emit — output is dist/index.js to match `bin`. */
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "removeComments": false,

    /* Strictness — the bar a reviewer would expect. */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,

    /* Interop / speed. */
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}
